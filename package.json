{
      "name": "portfolio-website",
      "version": "0.1.0",
      "private": true,
      "scripts": {
            "ts": "ts-node -P scripts/tsconfig.scripts.json",
            "dev": "next dev",
            "build": "next build",
            "start": "next start",
            "lint": "next lint",
            "export": "next build && next export",
            "generate:projects": "npm run generate:projects-manifest && npm run generate:projects-index",
            "generate:projects-manifest": "npm run ts -- scripts/generate-project-manifests.ts",
            "generate:projects-index": "npm run ts -- scripts/generate-project-index.ts",
            "generate:components": "npm run generate:components-classes && npm run generate:components-index && npm run generate:components-animationTypes && npm run generate:components-settingsTypes",
            "generate:components-classes": "npm run ts -- scripts/generate-component-classes.ts",
            "generate:components-index": "npm run ts -- scripts/generate-component-index.ts",
            "generate:components-animationTypes": "npm run ts -- scripts/generate-component-animationTypes.ts",
            "generate:components-settingsTypes": "npm run ts -- scripts/generate-component-settingTypes.ts",
            "generate:mui-theme-augmentation": "npm run ts -- scripts/generate-mui-theme-augmentation.ts",
            "generate:icons-transformed": "npm run ts -- scripts/generate-normalized-svgIcons.ts",
            "generate:icons-manifest": "npm run ts -- scripts/generate-icons-manifest.ts",
            "generate:resume": "npm run ts -- scripts/generate-resume-pdf.ts",
            "generate:all": "npm run generate:projects && npm run generate:components && npm run generate:mui-theme-augmentation && npm run generate:svg-icons",
            "serve": "npx serve out"
      },
      "dependencies": {
            "@emotion/react": "11.14.0",
            "@emotion/styled": "11.14.1",
            "@mui/icons-material": "7.3.4",
            "@mui/material": "7.3.4",
            "@mui/system": "7.3.2",
            "@mui/types": "7.3.1",
            "github-markdown-css": "5.8.1",
            "highlight.js": "11.11.1",
            "motion": "12.19.2",
            "next": "15.5.3",
            "react": "19.1.1",
            "react-dom": "19.1.1",
            "react-icons": "5.5.0",
            "react-markdown": "10.1.0",
            "react-player": "3.3.2",
            "react-syntax-highlighter": "15.6.6",
            "rehype-highlight": "7.0.2",
            "remark-gfm": "4.0.1"
      },
      "devDependencies": {
            "@eslint/eslintrc": "3",
            "@tailwindcss/postcss": "4.1.11",
            "@types/css": "0.0.38",
            "@types/ffprobe-static": "^2.0.3",
            "@types/glob": "8.1.0",
            "@types/jsdom": "27.0.0",
            "@types/node": "20",
            "@types/react": "19.2.0",
            "@types/react-dom": "19.2.0",
            "@types/react-syntax-highlighter": "15.5.13",
            "@types/webpack": "5.28.5",
            "@typescript-eslint/eslint-plugin": "8.50.0",
            "@typescript-eslint/parser": "8.50.0",
            "case-sensitive-paths-webpack-plugin": "2.4.0",
            "css": "3.0.0",
            "eslint": "9",
            "eslint-config-next": "15.3.4",
            "eslint-plugin-import": "2.32.0",
            "eslint-plugin-react": "7.37.5",
            "eslint-plugin-react-hooks": "7.0.1",
            "ffprobe-static": "^3.1.0",
            "glob": "11.0.3",
            "image-size": "2.0.2",
            "jsdom": "27.0.0",
            "postcss": "8.5.6",
            "puppeteer": "24.31.0",
            "svg-inline-loader": "0.8.2",
            "tailwindcss": "4.1.11",
            "ts-node": "10.9.2",
            "typescript": "5"
      }
}
