{
  "name": "portfolio-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ts": "ts-node -P scripts/tsconfig.scripts.json",
    "dev": "next dev",
    "build": "npm run generate:projects && next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next build && next export",
    "generate:projects": "npm run generate:projects-manifest && npm run generate:projects-index",
    "generate:projects-manifest": "npm run ts -- scripts/generate-project-manifests.ts",
    "generate:projects-index": "npm run ts -- scripts/generate-project-index.ts",
    "generate:components": "npm run generate:components-index && npm run generate:components-animationTypes && npm run generate:components-settingTypes",
    "generate:components-index": "npm run ts -- scripts/generate-component-index.ts",
    "generate:components-animationTypes": "npm run ts -- scripts/generate-component-animationTypes.ts",
    "generate:components-settingTypes": "npm run ts -- scripts/generate-component-settingTypes.ts",
    "generate:mui-theme-augmentation": "npm run ts -- scripts/generate-mui-theme-augmentation.ts",
    "serve": "npx serve out"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/material": "7.3.2",
    "@mui/system": "7.3.2",
    "@mui/types": "7.3.1",
    "highlight.js": "11.11.1",
    "motion": "12.19.2",
    "next": "15.5.3",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-icons": "5.5.0",
    "react-markdown": "10.1.0",
    "react-player": "3.3.2",
    "react-syntax-highlighter": "15.6.6",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "20",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/webpack": "5.28.5",
    "eslint": "9",
    "eslint-config-next": "15.3.4",
    "image-size": "2.0.2",
    "postcss": "8.5.6",
    "svg-inline-loader": "0.8.2",
    "tailwindcss": "4.1.11",
    "ts-node": "10.9.2",
    "typescript": "5"
  }
}
